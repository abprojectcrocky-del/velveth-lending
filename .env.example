# Supabase — get from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Functions URL (same base URL + /functions/v1)
VITE_SUPABASE_FUNCTIONS_URL=https://your-project-id.supabase.co/functions/v1

# Your deployed Vercel URL (used in email "View My Loan" links)
VITE_APP_URL=https://your-app.vercel.app
